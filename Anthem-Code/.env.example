# Copy to .env — use the SAME Supabase project as So1o when accounts are unified.

# Public site URL for SEO (canonical, OG, sitemap) — no trailing slash
# Production: https://aplus1.app
# เดโม่: https://aplus1-demo.vercel.app (ไม่ต้องตั้งบน Vercel preview — OAuth ใช้ window.location.origin)
# VITE_SITE_URL=https://aplus1.app
# Ops Hub — ecosystem monitor (admin only)
# VITE_OPS_HUB_URL=https://so1o-ops-hub.vercel.app

# แถบโหมดทดสอบ + คำแนะนำ login demo (เปิดบน Vercel demo)
# Demo must use a separate Supabase project. Never point these values at production.
# VITE_DEMO_MODE=true
# VITE_DEMO_SUPABASE_URL=https://your-demo-project.supabase.co
# VITE_DEMO_SUPABASE_PUBLISHABLE_KEY=your_demo_anon_key
# Keep reviewer passwords outside VITE_* variables; Vite variables are public in the browser bundle.

# --- Error monitoring (optional) ---
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- Vercel demo deploy (ตั้งใน Project → Settings → Environment Variables) ---
# จำเป็น: VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY, VITE_DEMO_MODE=true
# ไม่ต้องตั้ง VITE_SITE_URL บน preview — OAuth ใช้ window.location.origin อัตโนมัติ
# หลังได้ URL แล้ว เพิ่มใน Supabase → Auth → Redirect URLs: https://<project>.vercel.app/auth/callback

# Same project as So1o (unified ecosystem)
VITE_SUPABASE_URL=https://zkflkpbmbozrchqncpzi.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_PROJECT_ID=zkflkpbmbozrchqncpzi

# So1o My Desk (billing + back-office)
# Public URL of So1o (VPS / docker compose)
VITE_SO1O_APP_URL=http://localhost:3000
# VITE_LEGAL_WEBSITE=http://localhost:8081

# Aplus1 ↔ So1o — split flags for soft launch:
#   Payments (Stripe via Solo API): top-up, Connect, cashout, boost, ads
#   Ecosystem links: So1o My Desk, quotation, LINE link, /upgrade Pro UI
#
# Soft launch (payments on, Solo UI links still coming soon):
#   VITE_APLUS1_PAYMENTS_ENABLED=true
#   VITE_SO1O_APP_URL=https://solofreelancer.com
#
# Stripe mode (Aplus1 → Solo /api/payments/*):
#   local / demo  → sandbox (default) — บัตรทดสอบ 4242...
#   production    → live (set on Vercel aplus1-prod build)
#   VITE_STRIPE_MODE=sandbox   # local default via scripts/dev-server.mjs
#   VITE_STRIPE_MODE=live      # aplus1.app only
#
# Local with Solo dev server:
#   VITE_SO1O_APP_URL=http://localhost:3000
#   cd Solo-Code && npm run stripe:sync   # หลังตั้ง STRIPE_SANDBOX_API_KEY
#
# Full ecosystem (open all Solo links too):
#   VITE_SOLO_ECOSYSTEM_ENABLED=true
# Legacy alias: VITE_APLUS1_UPGRADE_ENABLED=true
#
# Payments — local dev auto-enables via scripts/dev-server.mjs:
VITE_APLUS1_PAYMENTS_ENABLED=true
# VITE_STRIPE_MODE=sandbox

# Optional: E2E (Playwright / Puppeteer — see docs/e2e-guide.md)
# E2E_USER_EMAIL=qa-user-a@example.com
# E2E_USER_PASSWORD=
# E2E_ADMIN_EMAIL=qa-admin@example.com
# E2E_ADMIN_PASSWORD=
# E2E_DEMO_EMAIL=phatsawut@demo.pixel100.com
# E2E_DEMO_PASSWORD=

# Legacy (separate projects only): So1o webhook → sync-so1o-tier edge function
# ECOSYSTEM_SYNC_SECRET=

# Supabase CLI only — do NOT put in .env (not VITE_*). Use in terminal:
# export SUPABASE_ACCESS_TOKEN=sbp_...   # https://supabase.com/dashboard/account/tokens
# npm run db:push
