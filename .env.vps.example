# Copy to repo root as .env for: docker compose up --build
# Also maintain Solo-Code/.env and Anthem-Code/.env for local dev (same values).
#
# Standalone deploy profiles:
#   anthem.env.example  → ./scripts/deploy-anthem.sh
#   ops-hub.env.example → ./scripts/deploy-ops-hub.sh

HTTP_PORT=80

# --- Unified Supabase (So1o + an1hem) ---
VITE_SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
VITE_SUPABASE_PROJECT_ID=rvnzjiskqliexysicfmh
SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

VITE_PAYMENTS_CLIENT_TOKEN=your_stripe_publishable_key
STRIPE_SANDBOX_API_KEY=your_stripe_test_secret_key
STRIPE_LIVE_API_KEY=
STRIPE_USE_DIRECT=true

GEMINI_API_KEY=

VITE_EARLY_ACCESS=false

# an1hem: แถบ demo + วิธี login สำหรับ UX reviewer (ปิดเป็น false ตอน production จริง)
VITE_DEMO_MODE=false

# Public URLs (must match deploy/nginx server_name + Supabase Auth redirect URLs)
VITE_SO1O_APP_URL=https://www.solofreelancer.com
VITE_ANTHEM_APP_URL=https://an1hem.app
VITE_OPS_HUB_URL=https://hq.solofreelancer.com

# an1hem uses the same project (optional overrides if identical)
ANTHEM_VITE_SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
ANTHEM_VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
ANTHEM_VITE_SUPABASE_PROJECT_ID=rvnzjiskqliexysicfmh
ANTHEM_SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
