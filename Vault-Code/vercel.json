{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/vault",
      "permanent": false
    },
    {
      "source": "/demo",
      "destination": "/vault",
      "permanent": true
    },
    {
      "source": "/demo.html",
      "destination": "/vault",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/vault",
      "destination": "/vault.html"
    },
    {
      "source": "/vault/",
      "destination": "/vault.html"
    },
    {
      "source": "/moodboards",
      "destination": "/vault.html"
    },
    {
      "source": "/moodboards/(.*)",
      "destination": "/vault.html"
    },
    {
      "source": "/400",
      "destination": "/400.html"
    },
    {
      "source": "/500",
      "destination": "/500.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/modules/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff2|png|svg|jpg|jpeg|webp|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
