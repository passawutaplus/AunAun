{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "echo no install needed",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/vault",
      "permanent": false
    },
    {
      "source": "/demo",
      "destination": "/vault",
      "permanent": true
    },
    {
      "source": "/demo.html",
      "destination": "/vault",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/vault",
      "destination": "/vault.html"
    },
    {
      "source": "/vault/",
      "destination": "/vault.html"
    },
    {
      "source": "/400",
      "destination": "/400.html"
    },
    {
      "source": "/500",
      "destination": "/500.html"
    }
  ]
}
