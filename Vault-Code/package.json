{
  "name": "a-plus-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run sitemap:gen && node build.mjs",
    "check": "npm run sitemap:gen && node scripts/qa.mjs",
    "alpha:smoke": "node scripts/alpha-smoke.mjs",
    "smoke:public": "bash scripts/smoke-public.sh",
    "smoke:api": "node scripts/prod-api-smoke.mjs",
    "sitemap:gen": "node scripts/generate-seo.mjs",
    "test": "node --test scripts/__tests__/*.test.mjs",
    "test:gate": "npm run check && npm run test && npm run alpha:smoke && npm run build",
    "deploy:demo": "bash scripts/deploy-demo-vercel.sh"
  }
}
